# Agent Zero low-CPU local Ollama profile
# Copy values you want into your .env as A0_SET_* overrides.
# This profile targets responsiveness on limited CPUs.

# Chat model (primary conversation)
A0_SET_chat_model_provider=ollama
A0_SET_chat_model_name=qwen2.5:7b
A0_SET_chat_model_api_base=http://host.docker.internal:11434
A0_SET_chat_model_ctx_length=16000
A0_SET_chat_model_ctx_history=0.4

# Utility model (summarization, memory extraction, internal processing)
A0_SET_util_model_provider=ollama
A0_SET_util_model_name=qwen2.5:3b
A0_SET_util_model_api_base=http://host.docker.internal:11434
A0_SET_util_model_ctx_length=8000
A0_SET_util_model_ctx_input=0.4

# Memory recall: reduce frequency and breadth for lower CPU usage
A0_SET_memory_recall_interval=8
A0_SET_memory_recall_memories_max_search=6
A0_SET_memory_recall_solutions_max_search=4
A0_SET_memory_recall_memories_max_result=3
A0_SET_memory_recall_solutions_max_result=2
A0_SET_memory_recall_query_prep=false
A0_SET_memory_recall_post_filter=false

# Memory write path: disable consolidation to reduce utility-model load
A0_SET_memory_memorize_consolidation=false

# Workdir tree limits: reduce filesystem scan / prompt payload size
A0_SET_workdir_max_depth=3
A0_SET_workdir_max_files=10
A0_SET_workdir_max_folders=10
A0_SET_workdir_max_lines=120
